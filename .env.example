# Copy to .env and fill in your Neon Postgres connection string.
# Get it from the Neon dashboard → your project → Connection Details
# (use the "Pooled connection" string).
#
# .env is gitignored; never commit real credentials.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require&channel_binding=require"
